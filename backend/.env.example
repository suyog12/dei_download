# DEI Downloader backend configuration.
# Copy to .env and fill in values as needed.

# Comma-separated list of allowed origins for CORS.
# In dev, Vite runs on 5173 by default.
CORS_ORIGINS=http://localhost:5173

# Year range bounds enforced at the API layer.
MIN_YEAR=2020
MAX_YEAR=2025

# Log verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Optional: Hugging Face token for higher rate limits when pulling the
# Anthropic Economic Index. The dataset is public (CC-BY) and works
# without a token; this just lifts the unauthenticated limit.
# HF_TOKEN=
