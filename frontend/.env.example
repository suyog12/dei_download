# Frontend env. Copy to .env.local if you need to override defaults.
#
# In development, Vite proxies /api/* to http://localhost:8000 via vite.config.ts,
# so you don't need to set anything.
#
# In production (e.g. hosting the frontend on Vercel and the backend elsewhere),
# set VITE_API_BASE to the absolute URL of the backend, without a trailing slash.

# VITE_API_BASE=https://dei-api.example.com
